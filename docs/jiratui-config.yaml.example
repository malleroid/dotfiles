# ~/.config/jiratui/config.yaml
# Copy and fill in real values:
#   mkdir -p ~/.config/jiratui
#   cp jiratui/config.yaml.example ~/.config/jiratui/config.yaml
#
# Token must be set directly here (jiratui's YAML takes priority over env vars)
# Get your token at: https://id.atlassian.com/manage-profile/security/api-tokens

# === Required ===
jira_api_token: 'your-api-token-here'
jira_api_username: 'your-email@example.com'
jira_api_base_url: 'https://your-instance.atlassian.net'

# === Recommended ===
jira_base_url: 'https://your-instance.atlassian.net'
default_project_key_or_id: 'MYPROJ'

# === UI ===
theme: 'tokyo-night'
confirm_before_quit: true

# === Search ===
search_results_per_page: 50
search_issues_default_day_interval: 15

# === Pre-defined JQL ===
# pre_defined_jql_expressions:
#   1:
#     label: "Current sprint"
#     expression: 'sprint in openSprints()'
#   2:
#     label: "My open issues"
#     expression: 'assignee = currentUser() AND resolution = Unresolved'
