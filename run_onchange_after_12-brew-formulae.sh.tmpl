#!/bin/bash
{{ if ne .chezmoi.os "darwin" -}}
exit 0
{{ end -}}

# Brewfile.formulae hash: {{ include "Brewfile.formulae" | sha256sum }}

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew not installed, skipping"
  exit 0
fi

echo "Installing Homebrew formulae..."
brew bundle --file={{ joinPath .chezmoi.sourceDir "Brewfile.formulae" | quote }}
