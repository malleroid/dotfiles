  "model": "claude-opus-4-6",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_secrets.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_project_dir.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_force_push.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_git_c.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard_shell_syntax.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); pct=$(echo \"$input\" | jq -r '.context_window.used_percentage // 0'); r5=$(echo \"$input\" | jq -r '.rate_limits.five_hour.used_percentage // empty'); r5_reset=$(echo \"$input\" | jq -r '.rate_limits.five_hour.resets_at // empty'); r7=$(echo \"$input\" | jq -r '.rate_limits.seven_day.used_percentage // empty'); acct=\"${CLAUDE_ACCOUNT:-personal}\"; if [ \"$acct\" != personal ]; then acct_disp=$(printf '\\033[1;37;41m %s \\033[0m' \"$acct\"); else acct_disp=$(printf '\\033[1;30;42m %s \\033[0m' \"$acct\"); fi; git_branch=$(git -C \"$cwd\" --no-optional-locks rev-parse --abbrev-ref HEAD 2>/dev/null); rl=\"\"; if [ -n \"$r5\" ]; then r5_reset_disp=\"\"; [ -n \"$r5_reset\" ] && r5_reset_disp=$(date -r \"$r5_reset\" '+ reset %H:%M' 2>/dev/null); rl=$(printf '5h:%.0f%%%s' \"$r5\" \"$r5_reset_disp\"); fi; [ -n \"$r7\" ] && rl=\"${rl:+$rl }$(printf '7d:%.0f%%' \"$r7\")\"; [ -n \"$rl\" ] && rl=\"   $rl\"; pct_int=$(printf '%.0f' \"$pct\"); if [ \"$pct_int\" -ge 90 ]; then ctx_disp=$(printf '\\033[1;31mctx:%s%%\\033[0m' \"$pct\"); elif [ \"$pct_int\" -ge 70 ]; then ctx_disp=$(printf '\\033[33mctx:%s%%\\033[0m' \"$pct\"); else ctx_disp=$(printf '\\033[32mctx:%s%%\\033[0m' \"$pct\"); fi; if [ -n \"$git_branch\" ]; then printf '%s  [%s]   %s   %s   %s%s' \"$acct_disp\" \"$model\" \"$cwd\" \"$git_branch\" \"$ctx_disp\" \"$rl\"; else printf '%s  [%s]   %s   %s%s' \"$acct_disp\" \"$model\" \"$cwd\" \"$ctx_disp\" \"$rl\"; fi"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "theme": "dark-ansi",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": false,
  "skipWorkflowUsageWarning": true
}
