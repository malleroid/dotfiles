{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*secrets*": "deny",
      "config/credentials.yml.enc": "deny",
      "id_rsa*": "deny",
      "id_ed25519*": "deny"
    },
    "edit": "ask",
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "allow",
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "df *": "allow",
      "du *": "allow",
      "file *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git check-ignore *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-tree *": "allow",
      "git reflog *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "rg *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "git push *": "ask",
      "git reset *": "ask",
      "git commit --amend*": "ask",
      "git commit --allow-empty*": "ask",
      "git commit --no-verify*": "ask",
      "gh api --method DELETE *": "ask",
      "gh api --method PATCH *": "ask",
      "gh api --method POST *": "ask",
      "gh api --method PUT *": "ask",
      "gh api -X DELETE *": "ask",
      "gh api -X PATCH *": "ask",
      "gh api -X POST *": "ask",
      "gh api -X PUT *": "ask",
      "gh pr create *": "ask",
      "gh pr merge *": "deny",
      "gh release create *": "ask",
      "gh release delete *": "ask",
      "gh release upload *": "ask",
      "gh repo archive *": "ask",
      "gh repo delete *": "ask",
      "gh repo rename *": "ask",
      "gh repo transfer *": "ask",
      "gh repo unarchive *": "ask",
      "gh run rerun *": "ask",
      "gh secret delete *": "ask",
      "gh secret set *": "ask",
      "gh variable delete *": "ask",
      "gh variable set *": "ask",
      "gh workflow disable *": "ask",
      "gh workflow enable *": "ask",
      "gh workflow run *": "ask"
    }
  }
}
