#!/usr/bin/env fish
#
# fetch-claude-code — fetch Claude Code releases from the last N days and print a
# losslessly-normalized JSON array to stdout. This is the deterministic fetch layer
# of the release-digest skill.
#
# Usage:  fetch-claude-code [days]      (defaults to 1)
# Output: [ { version, date, published_at, url, change_count, bugfix_only, changes[] } ]
#
# Invariants:
#   - exclude draft / prerelease
#   - keep every CHANGELOG bullet (classification & translation are the skill's LLM job)
#   - reuse gh's existing login for auth (5,000/hr authenticated vs 60/hr for anon curl)
#
# Portability: date math uses BSD `date -v`, i.e. macOS local only.
#   When moving to Linux / CI (cron), switch to GNU date: `TZ=Asia/Tokyo date -d "$days days ago" +%Y-%m-%d`.
# Window basis: JST calendar date (consistent with all other sources via bin/_window.py); the
# jq filter (normalize.jq) compares each published_at converted to its JST date against it.

set -l days $argv[1]
test -z "$days"; and set days 1

set -l cutoff (env TZ=Asia/Tokyo date -v-$days"d" +%Y-%m-%d)
set -l here (dirname (status filename))

gh api "repos/anthropics/claude-code/releases?per_page=100" \
  | jq --arg cutoff $cutoff -f "$here/normalize.jq"
