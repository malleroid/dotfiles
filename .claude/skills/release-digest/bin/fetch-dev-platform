#!/usr/bin/env fish
#
# fetch-dev-platform — fetch Claude Developer Platform (API) release notes from the last N days,
# normalized to the shared schema. Deterministic fetch layer of the release-digest skill.
#
# Usage:  fetch-dev-platform [days]      (defaults to 1)
# Output: [ { unit, date, url, change_count, changes[] } ]   (one element per dated section)
#
# Source: the raw Markdown of the docs release-notes page (the `.md` suffix), which is clean,
# date-headed, and deterministically parseable — no HTML scraping and no LLM in this layer.
# Portability: pure curl + python3, so it runs standalone (cron) without an agent.

set -l days $argv[1]
test -z "$days"; and set days 1

set -l here (dirname (status filename))

curl -sL https://platform.claude.com/docs/en/release-notes/overview.md \
  | python3 "$here/parse-relnotes.py" --days $days
