{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/guard_force_push.sh",
            "statusMessage": "Checking for force push"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/guard_git_c.sh",
            "statusMessage": "Checking git command shape"
          }
        ]
      },
      {
        "matcher": "^apply_patch$|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/guard_secrets.sh",
            "statusMessage": "Checking for sensitive files"
          }
        ]
      }
    ]
  }
}
